<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login - SISGESE</title>
<!-- Bootstrap 5.3 -->
<link
	href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
	rel="stylesheet">
<link rel="icon" href="/img/logo.ico" type="image/x-icon" />
<!-- Bootstrap Icons -->
<link rel="stylesheet"
	href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
<!-- Adicionando jQuery para a máscara -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<!-- Plugin jQuery Mask -->
<script
	src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>
<style>
* {
	box-sizing: border-box;
	
}

body, html {
	height: 100%;
	margin: 0;
	padding: 2px;
	font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;

}

body {
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(
        circle at center,
        #E5E7EB 0%,
        #2F3B73 60%,
        #1E2A5A 100%
    );
    overflow: hidden;
}

.login-wrapper {
    width: 100%;
    display: flex;
    justify-content: center;
}

.login-card {
    width: 100%;
    max-width: 420px;   /* menor */
    padding: 2.2rem 2.5rem;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.35);
}

.login-card:hover {
	transform: translateY(-5px);
}

/* Header do card com logo */
.login-header {
	text-align: center;
	margin-bottom: 2.5rem;
}

.logo {
	max-width: 150px; /* metade de 280 */
	height: auto;
	margin-top: 5rem;
	filter: drop-shadow(0 3px 6px rgba(0, 0, 0, 0.1));
}

.brand-title {
	font-size: 1.8rem;
	font-weight: 700;
	color: #2d3436;
	margin-bottom: 0.3rem;
	letter-spacing: 0.5px;
}

.brand-subtitle {
	color: #6c757d;
	font-size: 1rem;
	font-weight: 400;
	letter-spacing: 1.5px;
	text-transform: uppercase;
}

.login-title {
	text-align: center;
	font-size: 1.4rem;
	font-weight: 600;
	color: #2d3436;
	margin-bottom: 1.5rem;
	position: relative;
}

.login-title::after {
	content: '';
	position: absolute;
	bottom: -8px;
	left: 50%;
	transform: translateX(-50%);
	width: 60px;
	height: 3px;
	background: linear-gradient(to right, #1E2A5A, #F2C230);
	border-radius: 2px;
}

/* Opções de login */
.login-options {
	margin-bottom: 1.5rem;
	padding:2px;
}

.options-title {
	font-size: 1rem;
	font-weight: 500;
	color: #495057;
	margin-bottom: 0.8rem;
	display: block;
}

.options-group {
	display: flex;
	gap: 20px;
	flex-wrap: wrap;
}

.option-item {
	display: flex;
	align-items: center;
	cursor: pointer;
	padding: 5px 10px;
	border-radius: 8px;
	transition: background-color 0.3s;
}

.option-item:hover {
	background-color: rgba(108, 99, 255, 0.05);
}

.option-radio {
	display: none;
}

.radio-custom {
	width: 20px;
	height: 20px;
	border: 2px solid #c9749166;
	border-radius: 50%;
	margin-right: 8px;
	position: relative;
	transition: all 0.3s;
}

.option-radio:checked+.radio-custom {
	border-color: #1E2A5A;
	background-color: #1E2A5A;
}

.option-radio:checked+.radio-custom::after {
	content: '';
	position: absolute;
	top: 50%;
	left: 50%;
	transform: translate(-50%, -50%);
	width: 8px;
	height: 8px;
	background-color: white;
	border-radius: 50%;
}

.option-label {
	font-size: 0.95rem;
	color: #495057;
	cursor: pointer;
	transition: color 0.3s;
}

.option-radio:checked ~ .option-label {
	color: #1E2A5A;
	font-weight: 500;
}

/* Estilos dos inputs */
.form-group {
	margin-bottom: 1.5rem;
	position: relative;
}

.form-label {
	display: block;
	font-weight: 500;
	color: #495057;
	margin-bottom: 0.5rem;
	font-size: 0.95rem;
}

.form-control {
	width: 100%;
	padding: 14px 16px;
	font-size: 1rem;
	border: 1.5px solid #e0e0e0;
	border-radius: 12px;
	background-color: #f8f9fa;
	transition: all 0.3s;
}

.form-control:focus {
	border-color: #1E2A5A;
	background-color: white;
	box-shadow: 0 0 0 0.2rem rgba(108, 99, 255, 0.15);
	outline: none;
}

/* Ícone nos inputs */
.input-icon {
	position: absolute;
	right: 16px;
	top: 38px;
	color: #6c757d;
	font-size: 1.1rem;
}

/* Campo oculto para tipo de login */
#loginType {
	display: none;
}

/* Checkbox "Remember me" */
.remember-me {
	display: flex;
	align-items: center;
	margin-bottom: 1.5rem;
}

.remember-checkbox {
	width: 18px;
	height: 18px;
	margin-right: 10px;
	cursor: pointer;
}

.remember-label {
	font-size: 0.95rem;
	color: #495057;
	cursor: pointer;
}

/* Botão de login */
.login-btn {
	width: 100%;
	padding: 15px;
	background: linear-gradient(135deg, #2F3B73 0%, #1E2A5A 100%);
	color: white;
	border: none;
	border-radius: 12px;
	font-size: 1.1rem;
	font-weight: 600;
	cursor: pointer;
	transition: all 0.3s;
	margin-top: 0.5rem;
	margin-bottom: 2rem;
}

.login-btn:hover {
	transform: translateY(-2px);
	box-shadow: 0 10px 25px rgba(30, 42, 90, 0.4);
}

.login-btn:active {
	transform: translateY(0);
}

/* Divisor "or sign up using" */
.divider {
	display: flex;
	align-items: center;
	margin-bottom: 1.5rem;
	text-align: center;
}

.divider-line {
	flex: 1;
	height: 1px;
	background-color: #dee2e6;
}

.divider-text {
	padding: 0 15px;
	color: #6c757d;
	font-size: 0.9rem;
	font-weight: 500;
}

/* Botões sociais */
.social-login {
	display: flex;
	justify-content: center;
	gap: 15px;
	margin-bottom: 2rem;
}

.social-btn {
	width: 50px;
	height: 50px;
	border-radius: 50%;
	display: flex;
	align-items: center;
	justify-content: center;
	background: #f8f9fa;
	border: 1.5px solid #e0e0e0;
	cursor: pointer;
	transition: all 0.3s;
	font-size: 1.3rem;
	color: #495057;
}

.social-btn:hover {
	transform: translateY(-3px);
	box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
	background: white;
}

/* Link "Forgot Password" */
.forgot-password {
	text-align: center;
	margin-top: 1.5rem;
}

.forgot-link {
	color: #1E2A5A;
	text-decoration: none;
	font-weight: 500;
	font-size: 0.95rem;
	transition: color 0.3s;
}

.forgot-link:hover {
	color: #F2C230;
	text-decoration: underline;
}

/* Link de cadastro */
.signup-link {
	text-align: center;
	margin-top: 2rem;
	padding-top: 1.5rem;
	border-top: 1px solid #e9ecef;
	color: #6c757d;
	font-size: 0.95rem;
}

.signup-link a {
	color: #1E2A5A;
	text-decoration: none;
	font-weight: 600;
	margin-left: 5px;
}

.signup-link a:hover {
	text-decoration: underline;
}

/* Mensagem de erro */
.error-message {
	background-color: rgba(220, 53, 69, 0.1);
	color: #dc3545;
	padding: 12px 16px;
	border-radius: 8px;
	border-left: 4px solid #dc3545;
	margin-top: 15px;
	font-size: 0.95rem;
	text-align: center;
}

/* Responsividade */
@media ( max-width : 768px) {
	.login-wrapper {
		padding: 15px;
	}
	.login-card {
		padding: 2.5rem 2rem;
		max-width: 90%;
	}
	.logo {
		max-width: 150px;
	}
	.brand-title {
		font-size: 1.6rem;
	}
	.options-group {
		gap: 15px;
	}
}

@media ( max-width : 576px) {
	.login-card {
		padding: 2rem 1.5rem;
		max-width: 100%;
		border-radius: 20px;
	}
	.logo {
		max-width: 130px;
	}
	.brand-title {
		font-size: 1.4rem;
	}
	.login-title {
		font-size: 1.2rem;
	}
	.options-group {
		flex-direction: column;
		gap: 10px;
	}
	.option-item {
		padding: 8px 12px;
	}
	.form-control {
		padding: 12px 14px;
	}
	.login-btn {
		padding: 14px;
	}
}

/* Animações */
.fade-in {
	animation: fadeIn 0.6s ease-out;
}

@
keyframes fadeIn {from { opacity:0;
	transform: translateY(30px);
}

to {
	opacity: 1;
	transform: translateY(0);
}

}

/* Custom checkbox */
.custom-checkbox {
	display: flex;
	align-items: center;
	cursor: pointer;
}

.custom-checkbox input {
	display: none;
}

.checkbox-box {
	width: 18px;
	height: 18px;
	border: 2px solid #c9749166;
	border-radius: 4px;
	margin-right: 10px;
	display: flex;
	align-items: center;
	justify-content: center;
	transition: all 0.3s;
}

.custom-checkbox input:checked+.checkbox-box {
	background-color: #1E2A5A;
	border-color: #1E2A5A;
}

.custom-checkbox input:checked+.checkbox-box::after {
	content: '✓';
	color: white;
	font-size: 12px;
	font-weight: bold;
}

/* Placeholder styling */
::placeholder {
	color: #adb5bd;
	opacity: 1;
}

/* Transição suave para mudanças no campo */
.field-transition {
	transition: all 0.3s ease;
}

/* Badge para indicar padrão */
.default-badge {
	font-size: 0.7rem;
	background: linear-gradient(135deg, #1E2A5A 0%, #F2C230 100%);
	color: white;
	padding: 2px 6px;
	border-radius: 4px;
	margin-left: 6px;
	font-weight: 600;
}

.system-version {
    margin-top: 4px;
    margin-bottom: 20px;
    text-align: center;
    font-size: 0.70rem;
    color: #9aa0a6;
    font-weight: 400;
    letter-spacing: 0.4px;
}
</style>
</head>
<body>
	<!-- Container do background -->
	<div class="background-container"></div>


	<div class="login-wrapper">
		<div class="login-card fade-in">
			<!-- Header com logo -->
			<div class="login-header">
				<img th:src="@{/img/logo-sitema-opaco.png}" alt="Socioeducativo"
					class="logo">
				
			</div>

			<!-- Título do login -->
			<div class="login-title">Login - SISGESE</div>
<div class="system-version">Sistema de Gestão Socioeducativo.
					V.1.0.2026</div>
			<!-- Opções de tipo de login -->
			<div class="login-options">
				<span class="options-title">Entrar com:</span>
				<div class="options-group">
					<label class="option-item"> <input type="radio"
						class="option-radio" name="tipoLogin" value="login" checked>
						<span class="radio-custom"></span> <span class="option-label">
							Nome de Login <span class="default-badge">PADRÃO</span>
					</span>
					</label> <label class="option-item"> <input type="radio"
						class="option-radio" name="tipoLogin" value="matricula"> <span
						class="radio-custom"></span> <span class="option-label">Matrícula</span>
					</label> <label class="option-item"> <input type="radio"
						class="option-radio" name="tipoLogin" value="cpf"> <span
						class="radio-custom"></span> <span class="option-label">CPF</span>
					</label>
				</div>
			</div>

			<!-- Formulário -->
			<form th:action="@{/login}" method="post">
				<!-- Campo oculto para enviar o tipo de login -->
				<input type="hidden" id="loginType" name="loginType" value="login">

				<!-- Campo dinâmico baseado na seleção -->
				<div class="form-group">
					<label for="identificador" class="form-label"
						id="identificadorLabel">Nome de Login</label> <input type="text"
						class="form-control field-transition" name="identificador"
						id="identificador" placeholder="Digite seu nome de usuário"
						required autofocus> <i
						class="bi bi-person-circle input-icon" id="identificadorIcon"></i>
				</div>

				<!-- Password -->
				<div class="form-group">
					<label for="senha" class="form-label">Senha</label> <input
						type="password" class="form-control" name="senha" id="senha"
						placeholder="Digite sua senha" required> <i
						class="bi bi-lock input-icon" id="passwordIcon"></i>
				</div>

				<!-- Remember me -->
				<div class="remember-me">
					<label class="custom-checkbox"> <input type="checkbox"
						id="remember" name="remember"> <span class="checkbox-box"></span>
						<span class="remember-label">Lembrar</span>
					</label>
				</div>

				<!-- Botão de login -->
				<button type="submit" class="login-btn">Login</button>
			</form>

			<!-- Mensagem de erro -->
			<div th:if="${erro}" class="error-message" th:text="${erro}"></div>

			<!-- Divisor -->
			<div class="divider">
				<div class="divider-line"></div>
			</div>

			<!-- Forgot password -->
			<div class="forgot-password">
				<a href="/recuperar-senha" class="forgot-link">Recuperar Senha</a>
			</div>


		</div>
	</div>

	<script>
        $(document).ready(function(){
            // Elementos que serão modificados
            const $identificador = $('#identificador');
            const $identificadorLabel = $('#identificadorLabel');
            const $identificadorIcon = $('#identificadorIcon');
            const $loginType = $('#loginType');
            
            // Configurações para cada tipo de login (ORDEM: login, email, cpf)
            const tiposLogin = {
                login: {
                    label: 'Nome de Login',
                    placeholder: 'Digite seu nome de usuário',
                    icon: 'bi-person-circle',
                    mask: false,
                    validation: function(value) {
                        return value.length >= 3;
                    },
                    errorMessage: 'O nome de login deve ter pelo menos 3 caracteres.',
                    keyboardShortcut: '1'
                },
                matricula: {
                    label: 'Matrícula',
                    placeholder: 'Digite sua matrícula',
                    icon: 'bi-card-heading',
                    mask: false,
                    validation: function(value) {
                        return value.length >= 3;
                    },
                    errorMessage: 'Digite uma matrícula válida.'
                },
                cpf: {
                    label: 'CPF',
                    placeholder: '000.000.000-00',
                    icon: 'bi-person-vcard',
                    mask: '000.000.000-00',
                    validation: function(value) {
                        const cpf = value.replace(/\D/g, '');
                        return cpf.length === 11;
                    },
                    errorMessage: 'Por favor, digite um CPF válido com 11 dígitos.',
                    keyboardShortcut: '3'
                }
            };
            
            // Função para atualizar o campo baseado na seleção
            function atualizarCampo(tipo) {
                const config = tiposLogin[tipo];
                
                // Atualiza label
                $identificadorLabel.text(config.label);
                
                // Atualiza placeholder
                $identificador.attr('placeholder', config.placeholder);
                
                // Atualiza ícone
                $identificadorIcon.removeClass('bi-person-circle bi-envelope bi-person-vcard');
                $identificadorIcon.addClass(config.icon);
                
                // Remove máscara anterior
                if ($.mask && $.mask.unmask) {
                    $identificador.unmask();
                }
                
                // Aplica nova máscara se existir
                if (config.mask) {
                    $identificador.mask(config.mask, {
                        reverse: false,
                        placeholder: config.placeholder
                    });
                } else {
                    // Remove maxlength para campos sem máscara
                    $identificador.removeAttr('maxlength');
                }
                
                // Limpa o campo
                $identificador.val('');
                
                // Atualiza campo oculto
                $loginType.val(tipo);
                
                // Foco no campo
                $identificador.focus();
            }
            
            // Evento de mudança nos radio buttons
            $('input[name="tipoLogin"]').change(function() {
                const tipoSelecionado = $(this).val();
                atualizarCampo(tipoSelecionado);
            });
            
            // Inicializa com Nome de Login (padrão)
            atualizarCampo('login');
            
            // Validação do formulário
            $('form').submit(function(e) {
                const tipoAtual = $('input[name="tipoLogin"]:checked').val();
                const config = tiposLogin[tipoAtual];
                const valor = $identificador.val().trim();
                
                if (!config.validation(valor)) {
                    alert(config.errorMessage);
                    e.preventDefault();
                    return false;
                }
                
                // Para CPF, remove formatação antes de enviar
                if (tipoAtual === 'cpf') {
                    const cpfLimpo = valor.replace(/\D/g, '');
                    $identificador.val(cpfLimpo);
                }
                
                return true;
            });
            
            // Toggle password visibility
            $('#passwordIcon').on('click', function() {
                const passwordInput = $('#senha');
                const type = passwordInput.attr('type') === 'password' ? 'text' : 'password';
                passwordInput.attr('type', type);
                $(this).toggleClass('bi-lock bi-unlock');
            });
            
            // Atalhos de teclado para trocar tipo de login
            $(document).keydown(function(e) {
                // Alt+1 para Login (padrão), Alt+2 para Email, Alt+3 para CPF
                if (e.altKey) {
                    switch(e.key) {
                        case '1':
                            $('input[name="tipoLogin"][value="login"]').prop('checked', true).trigger('change');
                            e.preventDefault();
                            break;
                        case '2':
                            $('input[name="tipoLogin"][value="email"]').prop('checked', true).trigger('change');
                            e.preventDefault();
                            break;
                        case '3':
                            $('input[name="tipoLogin"][value="cpf"]').prop('checked', true).trigger('change');
                            e.preventDefault();
                            break;
                    }
                }
            });
            
            // Dica de atalhos de teclado (aparece brevemente no início)
            setTimeout(function() {
                console.log('Dica: Use Alt+1, Alt+2 ou Alt+3 para alternar rapidamente entre os tipos de login');
            }, 2000);
            
            // Anima a transição quando o usuário clica nas opções
            $('.option-item').on('click', function() {
                $(this).addClass('active');
                setTimeout(() => {
                    $(this).removeClass('active');
                }, 300);
            });
        });
    </script>
</body>
</html>
<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head th:fragment="head(title)">
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    
    <title th:text="${title} + ' - CliniSys'">CliniSys</title>
    
    <!-- Bootstrap 5.3 CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome local -->
    <link th:href="@{/fontawesome621/css/all.min.css}" rel="stylesheet">
    
    <!-- SB Admin 2 CSS local -->
    <link th:href="@{/sb-admin/css/sb-admin-2.min.css}" rel="stylesheet">
    
    <!-- CSS personalizado -->
    <link th:href="@{/css/styles.css}" rel="stylesheet">
    
    <!-- Bloco para CSS específico -->
    <th:block th:fragment="css"></th:block>
</head>
</html>
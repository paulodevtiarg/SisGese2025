						</ol>
					</nav>
				</div>
				<div class="col-12">
					<!-- Mensagens de erro e de ok -->
				</div>
				<div class="col-12">
					<div class="card">
						<div
							class="card-header card-header d-flex justify-content-between align-items-center fs-5 pr-custom-text  fw-semibold text-uppercase">
							Perfil</div>
						<div class="card-body">
							<div class="row">
								<div class="col-12">
									<form th:action="@{/perfil}" method="get" class="mb-3">
									<div class="row">
										<div class="col-4">
										<input type="text" name="nome" th:value="${nomeBusca}"
											placeholder="Buscar por nome" class="form-control">
										</div>
										<div class="col-4"><select name="status" class="form-select">
											<option value="ativos"
												th:selected="${statusFiltro == 'ativos'}">Ativos</option>
											<option value="inativos"
												th:selected="${statusFiltro == 'inativos'}">Inativos</option>
											<option value="todos"
												th:selected="${statusFiltro == 'todos'}">Todos</option>
										</select> </div>
										
										<div class="col-2"><select name="tamanho" class="form-select">
											<option value="10" th:selected="${tamanhoPagina == 10}">10</option>
											<option value="15" th:selected="${tamanhoPagina == 15}">15</option>
											<option value="20" th:selected="${tamanhoPagina == 20}">20</option>
											<option value="25" th:selected="${tamanhoPagina == 25}">25</option>
											<option value="30" th:selected="${tamanhoPagina == 30}">30</option>
										</select></div>
										<div class="col-2"><button type="submit" class="btn btn-primary fs-6"><i class="fa-duotone fa-regular fa-magnifying-glass"></i>Buscar</button></div>
									
									</div>
										

										

										
									</form>
								</div>
								<div class="col-12">
									<table class="table table-bordered">
										<thead>
											<tr>
												<th>ID</th>
												<th>Descrição</th>
												<th>Status</th>
											</tr>
										</thead>
										<tbody>
											<tr th:each="perfil : ${perfis}">
												<td th:text="${perfil.id}"></td>
												<td th:text="${perfil.descricao}"></td>
												<td th:text="${perfil.status == 1 ? 'Ativo' : 'Inativo'}"></td>
											</tr>
										</tbody>
									</table>


								</div>
							</div>

						</div>
						<div class="card-footer d-flex justify-content-end">

							<nav aria-label="Paginação">
								<ul class="pagination mb-0">

									<!-- Anterior -->
									<li class="page-item"
										th:classappend="${paginaAtual == 0} ? 'disabled'"><a
										class="page-link"
										th:href="@{/perfil(pagina=${paginaAtual - 1}, nome=${nomeBusca}, status=${statusFiltro}, tamanho=${tamanhoPagina})}">
											Anterior </a></li>

									<!-- Números -->
									<li th:each="i : ${#numbers.sequence(0, totalPaginas-1)}"
										class="page-item"
										th:classappend="${i == paginaAtual} ? 'active'"><a
										class="page-link"
										th:href="@{/perfil(pagina=${i}, nome=${nomeBusca}, status=${statusFiltro}, tamanho=${tamanhoPagina})}"
										th:text="${i + 1}"> </a></li>

									<!-- Próxima -->
									<li class="page-item"
										th:classappend="${paginaAtual + 1 >= totalPaginas} ? 'disabled'">
										<a class="page-link"
										th:href="@{/perfil(pagina=${paginaAtual + 1}, nome=${nomeBusca}, status=${statusFiltro}, tamanho=${tamanhoPagina})}">
											Próxima </a>
									</li>

								</ul>
							</nav>

						</div>

					</div>
				</div>

			</div>

		</div>

	</div>
</body>
